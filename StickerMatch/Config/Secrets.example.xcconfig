// StickerMatch — Secrets template.
// Copy this file to "Secrets.xcconfig" (same folder) and fill in your values.
// Secrets.xcconfig is gitignored. See README for full setup.
//
// In Xcode: Project > Info > Configurations > set Debug & Release to use Secrets.xcconfig,
// then add these to the target's Info.plist:
//   SUPABASE_HOST     = $(SUPABASE_HOST)
//   SUPABASE_ANON_KEY = $(SUPABASE_ANON_KEY)

// Your Supabase project host WITHOUT the scheme (no "https://").
// Example: abcdwxyzproject.supabase.co
SUPABASE_HOST = YOUR_PROJECT_HOST.supabase.co

// Your Supabase anon/public key (Project Settings > API).
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
